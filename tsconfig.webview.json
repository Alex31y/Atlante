{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "./dist/webview",
    "rootDir": "./src",
    "composite": true
  },
  "include": [
    "src/webview/**/*",
    "src/shared/**/*"
  ]
}
